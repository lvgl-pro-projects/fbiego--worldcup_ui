<screen>
	<styles>
		<style
			name="style_main"
			bg_color="0x000000"
			bg_image_src="background"
			bg_image_tiled="true"
			bg_image_recolor="0x000000"
			bg_image_recolor_opa="150"
			pad_ver="20"
			pad_row="0"
			layout="flex"
			flex_flow="column"
			flex_main_place="space_between"
			flex_cross_place="center"
			flex_track_place="center"
			text_color="0xFFFFFF"
		/>
		<style
			name="style_panel"
			width="100%"
			height="content"
			pad_row="12"
			layout="flex"
			flex_flow="column"
			flex_cross_place="center"
			flex_track_place="center"
			text_color="0xFFFFFF"
			text_font="NS_Medium_36"
		/>
	</styles>
	<view extends="lv_obj" scrollable="false">
		<style name="style_main" />

		<lv_image src="lvgl_logo" />

		<lv_obj>
			<remove_style_all />
			<style name="style_panel" />

			<lv_label text="FIFA World Cup" style_text_font="NS_Medium_24" />
			<team_panel />
			<score_panel width="90%" />
			<lv_label bind_text="sb_status" style_text_font="NS_Medium_24" />
			<lv_label
				width="90%"
				bind_text="sb_referee"
				style_text_font="NS_Medium_18"
				style_text_align="center"
				long_mode="scroll_circular"
			/>
		</lv_obj>
		<lv_label width="90%" bind_text="sb_time_date" style_text_font="NS_Medium_18" style_text_align="center" />
		<lv_label width="90%" bind_text="sb_connection" style_text_font="NS_Medium_18" style_text_align="center" />
	</view>
</screen>
